-- ===== OFFSETS =====
local RIGHT_OFFSET = Vector3.new(-3, 2.5, 4)
local LEFT_OFFSET  = Vector3.new(3, 2.5, 4)
local FRONT_OFFSET = Vector3.new(0, 0.1, -5.5)
local VANISH_OFFSET = Vector3.new(0, -600, 0)

local STAND_OFFSET = (getgenv().standPosition == "left") and LEFT_OFFSET or RIGHT_OFFSET
