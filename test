--2MAIN CODE

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TextChatService = game:GetService("TextChatService")
local VIM = game:GetService("VirtualInputManager")

local lp = Players.LocalPlayer
local targetName = getgenv().TargetPlayer
local OWNER_NAME = "devtrav23"

-- ===== SETTINGS =====
local autoDefend = false
local lastDefendTime = 0

-- ===== CHAT =====
local function say(msg)
	local ch = TextChatService.ChatInputBarConfiguration.TargetTextChannel
	if ch then ch:SendAsync(msg) end
end

-- ===== EXPLOIT =====
pcall(function()
	sethiddenproperty(lp, "SimulationRadius", math.huge)
	sethiddenproperty(lp, "MaxSimulationRadius", math.huge)
end)

-- ===== OFFSETS =====
local RIGHT_OFFSET = Vector3.new(-3, 2.5, 4)
local LEFT_OFFSET  = Vector3.new(3, 2.5, 4)
local FRONT_OFFSET = Vector3.new(0, 0.1, -5.5)
local VANISH_OFFSET = Vector3.new(0, -600, 0)
local BEHIND_OFFSET = Vector3.new(0, 0, 6)

local STAND_OFFSET = (getgenv().standPosition == "left") and LEFT_OFFSET or RIGHT_OFFSET
local ACTIVE_OFFSET = STAND_OFFSET

local vanished = true
local lowHPSaid = false
local isAttacking = false

-- ===== CHARACTER =====
local char = lp.Character or lp.CharacterAdded:Wait()
local hrp = char:WaitForChild("HumanoidRootPart")
local hum = char:WaitForChild("Humanoid")
hum.PlatformStand = true

local animateScript = char:FindFirstChild("Animate")
if animateScript then animateScript.Disabled = true end

-- ===== IDLE ANIMATION =====
local idleAnim = Instance.new("Animation")
idleAnim.AnimationId = "rbxassetid://17124061663"

local idleTrack
local animator = hum:WaitForChild("Animator")

local function playIdle()
	if vanished or isAttacking then return end
	
	if idleTrack then
		idleTrack:Stop()
		idleTrack:Destroy()
	end
	
	idleTrack = animator:LoadAnimation(idleAnim)
	idleTrack.Priority = Enum.AnimationPriority.Action4
	idleTrack.Looped = true
	idleTrack:Play()
	
	idleTrack.Stopped:Connect(function()
		if not vanished and not isAttacking then
			task.delay(0.1, playIdle)
		end
	end)
end

local function stopIdle()
	if idleTrack then idleTrack:Stop() end
end

-- ===== AUTO DEFEND =====
local function getClosestAttacker(ownerHRP)
	local closestPlayer = nil
	local closestDist = 6
	
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= lp and plr.Character and plr.Name ~= OWNER_NAME then
			local theirHRP = plr.Character:FindFirstChild("HumanoidRootPart")
			if theirHRP then
				local dist = (ownerHRP.Position - theirHRP.Position).Magnitude
				if dist < closestDist then
					closestDist = dist
					closestPlayer = theirHRP
				end
			end
		end
	end
	return closestPlayer
end

local function autoDefendAttack(attackerHRP)
	if not attackerHRP then return end
	
	isAttacking = true
	stopIdle()
	ACTIVE_OFFSET = FRONT_OFFSET
	
	-- Auto skill spam
	for i = 1, 4 do
		local key = Enum.KeyCode["" .. i]
		press(key)
		task.wait(0.35)
	end
	
	task.delay(2.5, function()
		isAttacking = false
		ACTIVE_OFFSET = STAND_OFFSET
		if not vanished then playIdle() end
	end)
end

-- ===== DAMAGE RECOVERY =====
hum.HealthChanged:Connect(function()
	if not vanished and not isAttacking and hum.Health < hum.MaxHealth then
		task.delay(0.2, playIdle)
	end
end)

-- ===== OWNER DAMAGE DETECTION =====
local function setupOwnerDefend()
	local owner = Players:FindFirstChild(OWNER_NAME)
	if not owner then return end
	
	owner.CharacterAdded:Connect(function()
		task.wait(1)
		local ownerHum = owner.Character:FindFirstChild("Humanoid")
		if ownerHum then
			ownerHum.HealthChanged:Connect(function(health)
				if autoDefend and health < ownerHum.MaxHealth and tick() - lastDefendTime > 3 then
					lastDefendTime = tick()
					local ownerHRP = owner.Character:FindFirstChild("HumanoidRootPart")
					if ownerHRP then
						local attacker = getClosestAttacker(ownerHRP)
						if attacker then
							autoDefendAttack(attacker)
						end
					end
				end
			end)
		end
	end)
end

setupOwnerDefend()

