-- ===== SKILLS =====
local keyMap = {
	[getgenv().SkillWord1] = Enum.KeyCode.One,
	[getgenv().SkillWord2] = Enum.KeyCode.Two,
	[getgenv().SkillWord3] = Enum.KeyCode.Three,
	[getgenv().SkillWord4] = Enum.KeyCode.Four
}

local skillQuotes = {
	[getgenv().SkillWord1] = getgenv().Skill1Quote,
	[getgenv().SkillWord2] = getgenv().Skill2Quote,
	[getgenv().SkillWord3] = getgenv().Skill3Quote,
	[getgenv().SkillWord4] = getgenv().Skill4Quote
}

local cooldowns = {
	[getgenv().SkillWord1] = 20,
	[getgenv().SkillWord2] = 15,
	[getgenv().SkillWord3] = 10,
	[getgenv().SkillWord4] = 20
}

local lastUsed = {}
local saidCD = {}

local function press(k)
	VIM:SendKeyEvent(true, k, false, game)
	task.wait(0.05)
	VIM:SendKeyEvent(false, k, false, game)
end

-- ===== TARGET =====
local function getTargetHRP()
	local p = Players:FindFirstChild(targetName)
	return p and p.Character and p.Character:FindFirstChild("HumanoidRootPart")
end

-- ===== CHAT HOOK =====
local function hook(p)
	p.Chatted:Connect(function(m)
		m = m:lower():gsub("%s+", "")

		-- AUTO DEFEND TOGGLE (Silent)
		if m == ".ad" then
			autoDefend = not autoDefend
			-- No message shown
			return
		end

		-- SUMMON
		if m == getgenv().SummonWord and hum.Health/hum.MaxHealth > 0.25 then
			vanished = false
			lowHPSaid = false
			isAttacking = false
			say(math.random(1,2)==1 and getgenv().SummonQuote1 or getgenv().SummonQuote2)
			task.wait(0.3)
			playIdle()
			return
		end

		-- DISMISS
		if m == getgenv().DismissWord then
			vanished = true
			isAttacking = false
			stopIdle()
			say(math.random(1,2)==1 and getgenv().DismissQuote1 or getgenv().DismissQuote2)
			return
		end

		-- SKILLS
		if keyMap[m] and not vanished then
			local now = tick()
			if now - (lastUsed[m] or 0) < cooldowns[m] then
				if not saidCD[m] then
					saidCD[m] = true
					say(getgenv().CooldownQuote)
				end
				return
			end

			lastUsed[m] = now
			saidCD[m] = false

			isAttacking = true
			stopIdle()
			ACTIVE_OFFSET = FRONT_OFFSET

			say(skillQuotes[m])
			press(keyMap[m])

			task.delay(1.8, function()
				isAttacking = false
				if not vanished then
					ACTIVE_OFFSET = STAND_OFFSET
					playIdle()
				end
			end)
		end
	end)
end

-- ===== CONNECT =====
for _, p in ipairs(Players:GetPlayers()) do
	if p.Name == targetName then hook(p) end
end

Players.PlayerAdded:Connect(function(p)
	if p.Name == targetName then hook(p) end
end)

-- ===== MAIN LOOP =====
RunService.Heartbeat:Connect(function()
	local t = getTargetHRP()
	if not t then return end

	if hum.Health / hum.MaxHealth <= 0.25 then
		if not lowHPSaid then
			lowHPSaid = true
			say(getgenv().LowHPQuote)
		end
		vanished = true
		isAttacking = false
		stopIdle()
	end

	if vanished then
		bp.Position = t.Position + VANISH_OFFSET
		bg.CFrame = t.CFrame
	else
		bp.Position = t.CFrame:PointToWorldSpace(ACTIVE_OFFSET)
		bg.CFrame = t.CFrame
	end
end)

-- Anti-falling
RunService.Heartbeat:Connect(function()
	if not vanished and hum:GetState() == Enum.HumanoidStateType.Freefall then
		hum:ChangeState(Enum.HumanoidStateType.RunningNoPhysics)
	end
end)

