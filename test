-- ===== IDLE ANIMATION =====
local idleAnim = Instance.new("Animation")
idleAnim.AnimationId = "rbxassetid://17124061663"

local idleTrack
local animator = hum:WaitForChild("Animator")

local function playIdle()
	if vanished or isAttacking then return end
	if idleTrack and idleTrack.IsPlaying then return end
	
	if idleTrack then idleTrack:Destroy() end
	
	idleTrack = animator:LoadAnimation(idleAnim)
	idleTrack.Priority = Enum.AnimationPriority.Action4
	idleTrack.Looped = true
	idleTrack:Play()
end

local function stopIdle()
	if idleTrack then idleTrack:Stop() end
end

-- ===== SKILLS SETUP =====
local keyMap = {
	[getgenv().SkillWord1 and getgenv().SkillWord1:lower()] = Enum.KeyCode.One,
	[getgenv().SkillWord2 and getgenv().SkillWord2:lower()] = Enum.KeyCode.Two,
	[getgenv().SkillWord3 and getgenv().SkillWord3:lower()] = Enum.KeyCode.Three,
	[getgenv().SkillWord4 and getgenv().SkillWord4:lower()] = Enum.KeyCode.Four
}

local skillQuotes = { ... } -- ← Make sure this table is filled correctly
local cooldowns = { ... }   -- ← Make sure this table is filled correctly
local lastUsed = {}
local saidCD = {}

local function press(k)
	VIM:SendKeyEvent(true, k, false, game)
	task.wait(0.05)
	VIM:SendKeyEvent(false, k, false, game)
end

-- ===== AUTO DEFEND =====
local function getRandomAvailableSkill()
	local available = {}
	local now = tick()

	for word, key in pairs(keyMap) do
		if word then
			local cd = cooldowns[word] or 0
			local last = lastUsed[word] or 0
			
			if now - last >= cd then
				table.insert(available, {word = word, key = key})
			end
		end
	end

	if #available == 0 then return nil end
	return available[math.random(1, #available)]
end

local function autoDefendAttack(attackerHRP)
	if not attackerHRP or isAttacking then return end
	
	isAttacking = true
	stopIdle()
	ACTIVE_OFFSET = FRONT_OFFSET
	
	local skill = getRandomAvailableSkill()
	
	if skill then
		lastUsed[skill.word] = tick()
		press(skill.key)
	end
	
	task.delay(2.8, function()
		isAttacking = false
		ACTIVE_OFFSET = STAND_OFFSET
		if not vanished then playIdle() end
	end)
end

-- ===== HELPER FUNCTIONS =====
local function getClosestAttacker(ownerHRP)
	local closest = nil
	local minDist = 6
	
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr.Character and plr.Name ~= OWNER_NAME and plr ~= lp then
			local aHRP = plr.Character:FindFirstChild("HumanoidRootPart")
			if aHRP then
				local dist = (ownerHRP.Position - aHRP.Position).Magnitude
				if dist < minDist then
					minDist = dist
					closest = aHRP
				end
			end
		end
	end
	return closest
end

local function setupOwnerDefend()
	local owner = Players:FindFirstChild(OWNER_NAME)
	if not owner then return end
	
	if ownerHumConnection then ownerHumConnection:Disconnect() end
	
	local function connectHealth()
		if owner.Character then
			local hum = owner.Character:FindFirstChild("Humanoid")
			if hum then
				ownerHumConnection = hum.HealthChanged:Connect(function(health)
					if autoDefend and health < hum.MaxHealth and tick() - lastDefendTime > 2.5 then
						lastDefendTime = tick()
						local ownerHRP = owner.Character:FindFirstChild("HumanoidRootPart")
						if ownerHRP then
							local attacker = getClosestAttacker(ownerHRP)
							if attacker then
								autoDefendAttack(attacker)
							end
						end
					end
				end)
			end
		end
	end
	
	connectHealth()
	
	owner.CharacterAdded:Connect(function()
		task.wait(0.8)
		connectHealth()
	end)
end

setupOwnerDefend()

